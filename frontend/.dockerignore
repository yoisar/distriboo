# Dependencias (se instalan en el container)
node_modules
npm-debug.log*

# Build output
.next
out

# Archivos de entorno locales — NO deben entrar al container.
# Las variables NEXT_PUBLIC_* se pasan como build args desde docker-compose.
# Si estos archivos entran, Next.js puede tomarlos durante el build
# y pisar los build args, dejando la URL incorrecta horneada en el bundle.
.env.local
.env.development.local
.env.test.local
.env.production.local

# Control de versiones
.git
.gitignore

# Editor / OS
.DS_Store
.vscode
*.swp
*.swo
