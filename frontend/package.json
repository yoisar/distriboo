{
  "name": "distriboo-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report",
    "test:super-admin": "npx playwright test --grep 'Super Admin'",
    "test:revendedor": "npx playwright test --grep 'Revendedor'",
    "test:distribuidor": "npx playwright test --grep 'Distribuid'",
    "test:cliente": "npx playwright test --grep 'Cliente'",
    "test:scenarios": "npx playwright test tests/e2e/scenarios/",
    "test:auth": "npx playwright test tests/e2e/auth/",
    "test:landing": "npx playwright test tests/e2e/landing/"
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
