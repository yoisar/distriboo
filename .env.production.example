# ====================================
# Distriboo - Production Environment
# ====================================

# App
APP_NAME=Distriboo
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GENERATE_NEW_KEY_HERE

# Database
PROD_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PROD_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# Docker
COMPOSE_PROJECT_NAME=distriboo_prod

# Sanctum
SANCTUM_STATEFUL_DOMAINS=distriboo.yoisar.com
SESSION_DOMAIN=distriboo.yoisar.com

# Mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=pedidos@distriboo.yoisar.com
MAIL_FROM_NAME="Distriboo"
